# Copy to .env and fill in.

# --- GCP ---
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1
GCS_BUCKET=gh-archive-pipeline      # must be globally unique; terraform prefixes with project

# BigQuery datasets created by terraform
BQ_DATASET_RAW=gh_raw
BQ_DATASET_STAGING=gh_staging
BQ_DATASET_MARTS=gh_marts

# Path to a service account key json used by dlt/dbt/spark locally.
# Terraform creates the SA and writes the key to this path.
GOOGLE_APPLICATION_CREDENTIALS=./infra/terraform/sa-key.json

# --- GitHub ---
# Personal access token with public_repo scope, used by the streaming producer.
# Unauthenticated calls to /events are rate-limited to 60/hr; authenticated gets 5000/hr.
GITHUB_TOKEN=ghp_replace_me

# --- Kafka (local via docker-compose) ---
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=gh_events

# --- Kestra (local via docker-compose) ---
KESTRA_URL=http://localhost:8080
